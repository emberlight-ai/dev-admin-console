# Copy this file to /home/ubuntu/dev-admin-console/.env.production
# and fill in real values before running `npm run build`.
#
# Required (client + server)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional (server admin access; if omitted, anon key is used)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Admin console login (used by src/actions/auth.ts)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_me"

# Optional (used by src/lib/gemini.ts if you enable chat route)
GOOGLE_API_KEY="YOUR_GEMINI_API_KEY"


